---
import BaseLayout from "../layouts/BaseLayout.astro";

const year = new Date().getFullYear();
---

<BaseLayout>
  <header class="fixed top-0 z-50 w-full border-b border-white/10 bg-gensteel-blue/95 backdrop-blur-sm">
    <nav class="mx-auto flex max-w-7xl items-center justify-between px-6 py-4" aria-label="Main navigation">
      <a href="/" class="flex items-center gap-3 text-white no-underline">
        <img src="/images/logo.jpg" alt="Gensteel" class="h-10 w-auto" width="58" height="33" />
        <span class="font-heading text-2xl font-bold tracking-tight">
          <span class="text-gensteel-orange">GEN</span>STEEL
        </span>
      </a>
      <div class="hidden items-center gap-8 md:flex">
        <a href="/about" class="text-sm font-medium text-white/80 transition-colors hover:text-gensteel-orange">About</a>
        <a href="/#services" class="text-sm font-medium text-white/80 transition-colors hover:text-gensteel-orange">Services</a>
        <a href="/projects" class="text-sm font-medium text-white/80 transition-colors hover:text-gensteel-orange">Projects</a>
        <a href="/blog" class="text-sm font-medium text-white/80 transition-colors hover:text-gensteel-orange">News</a>
        <a href="/contact" class="rounded-md bg-gensteel-orange px-5 py-2.5 text-sm font-semibold text-white transition-colors hover:bg-gensteel-orange/90">Contact</a>
      </div>
    </nav>
  </header>

  <!-- Hero -->
  <section class="bg-gensteel-blue px-6 pb-16 pt-32">
    <div class="mx-auto max-w-3xl text-center">
      <p class="mb-3 font-heading text-sm font-semibold uppercase tracking-[0.2em] text-gensteel-orange">Get In Touch</p>
      <h1 class="font-heading text-4xl font-bold leading-tight text-white sm:text-5xl">
        Connect With Gensteel
      </h1>
      <p class="mt-4 text-lg text-white/70">
        Ready to start your next project? Give us a call or fill out the form below.
      </p>
    </div>
  </section>

  <!-- Contact Content -->
  <section class="bg-white px-6 py-24">
    <div class="mx-auto max-w-5xl">
      <div class="grid gap-16 lg:grid-cols-5">
        <!-- Contact Info Sidebar -->
        <div class="lg:col-span-2">
          <div class="space-y-8">
            <div class="flex items-start gap-4">
              <div class="mt-0.5 rounded-lg bg-gensteel-orange/10 p-2">
                <svg class="h-5 w-5 text-gensteel-orange" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />
                </svg>
              </div>
              <div>
                <h3 class="font-heading text-sm font-semibold text-steel-900">Location</h3>
                <p class="mt-1 text-steel-600">
                  28 Erinville Drive<br />
                  Erin, Ontario<br />
                  N0B 1T0
                </p>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="mt-0.5 rounded-lg bg-gensteel-orange/10 p-2">
                <svg class="h-5 w-5 text-gensteel-orange" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z" />
                </svg>
              </div>
              <div>
                <h3 class="font-heading text-sm font-semibold text-steel-900">Phone &amp; Fax</h3>
                <p class="mt-1 text-steel-600">
                  <a href="tel:+15198338555" class="transition-colors hover:text-gensteel-orange">Tel: +1 (519) 833-8555</a><br />
                  Fax: +1 (519) 833-1110
                </p>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="mt-0.5 rounded-lg bg-gensteel-orange/10 p-2">
                <svg class="h-5 w-5 text-gensteel-orange" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
                </svg>
              </div>
              <div>
                <h3 class="font-heading text-sm font-semibold text-steel-900">Email</h3>
                <p class="mt-1 text-steel-600">
                  <a href="mailto:info@gensteel.ca" class="transition-colors hover:text-gensteel-orange">info@gensteel.ca</a>
                </p>
              </div>
            </div>

            <div class="border-t border-steel-200 pt-6">
              <h3 class="mb-2 font-heading text-sm font-semibold text-steel-900">Business Hours</h3>
              <ul class="space-y-1 text-sm text-steel-600">
                <li class="flex justify-between"><span>Monday – Friday</span><span>7:00 AM – 5:00 PM</span></li>
                <li class="flex justify-between"><span>Saturday</span><span>By Appointment</span></li>
                <li class="flex justify-between"><span>Sunday</span><span>Closed</span></li>
              </ul>
            </div>
          </div>
        </div>

        <!-- Contact Form -->
        <div class="lg:col-span-3">
          <div class="rounded-2xl border border-steel-200 bg-steel-50 p-8 lg:p-10">
            <h2 class="mb-2 font-heading text-2xl font-bold text-steel-900">Send Us a Message</h2>
            <p class="mb-8 text-sm text-steel-500">
              Fill out the form and we'll get back to you promptly.
            </p>
            <form
              id="contact-form"
              class="space-y-6"
              method="POST"
              action="/api/contact"
            >
              <div class="grid gap-6 sm:grid-cols-2">
                <div>
                  <label for="first-name" class="mb-1.5 block font-heading text-sm font-semibold text-steel-900">
                    First Name <span class="text-gensteel-orange">*</span>
                  </label>
                  <input
                    id="first-name"
                    name="firstName"
                    type="text"
                    required
                    class="w-full rounded-lg border border-steel-300 bg-white px-4 py-3 text-sm text-steel-900 placeholder:text-steel-400 focus:border-gensteel-orange focus:outline-none focus:ring-2 focus:ring-gensteel-orange/20"
                    placeholder="John"
                  />
                </div>
                <div>
                  <label for="last-name" class="mb-1.5 block font-heading text-sm font-semibold text-steel-900">
                    Last Name <span class="text-gensteel-orange">*</span>
                  </label>
                  <input
                    id="last-name"
                    name="lastName"
                    type="text"
                    required
                    class="w-full rounded-lg border border-steel-300 bg-white px-4 py-3 text-sm text-steel-900 placeholder:text-steel-400 focus:border-gensteel-orange focus:outline-none focus:ring-2 focus:ring-gensteel-orange/20"
                    placeholder="Doe"
                  />
                </div>
              </div>
              <div>
                <label for="phone" class="mb-1.5 block font-heading text-sm font-semibold text-steel-900">
                  Phone
                </label>
                <input
                  id="phone"
                  name="phone"
                  type="tel"
                  class="w-full rounded-lg border border-steel-300 bg-white px-4 py-3 text-sm text-steel-900 placeholder:text-steel-400 focus:border-gensteel-orange focus:outline-none focus:ring-2 focus:ring-gensteel-orange/20"
                  placeholder="(519) 555-0123"
                />
              </div>
              <div>
                <label for="email" class="mb-1.5 block font-heading text-sm font-semibold text-steel-900">
                  Email <span class="text-gensteel-orange">*</span>
                </label>
                <input
                  id="email"
                  name="email"
                  type="email"
                  required
                  class="w-full rounded-lg border border-steel-300 bg-white px-4 py-3 text-sm text-steel-900 placeholder:text-steel-400 focus:border-gensteel-orange focus:outline-none focus:ring-2 focus:ring-gensteel-orange/20"
                  placeholder="john@company.com"
                />
              </div>
              <div>
                <label for="message" class="mb-1.5 block font-heading text-sm font-semibold text-steel-900">
                  Message <span class="text-gensteel-orange">*</span>
                </label>
                <textarea
                  id="message"
                  name="message"
                  rows={5}
                  required
                  class="w-full rounded-lg border border-steel-300 bg-white px-4 py-3 text-sm text-steel-900 placeholder:text-steel-400 focus:border-gensteel-orange focus:outline-none focus:ring-2 focus:ring-gensteel-orange/20"
                  placeholder="Tell us about your project..."
                ></textarea>
              </div>
              <button
                type="submit"
                class="inline-flex w-full items-center justify-center rounded-lg bg-gensteel-orange px-8 py-4 font-heading text-base font-semibold text-white transition-all hover:bg-gensteel-orange/90 hover:shadow-lg hover:shadow-gensteel-orange/25"
              >
                Send Message →
              </button>
            </form>
            <p id="form-status" class="mt-4 text-center text-sm text-steel-500 hidden"></p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="bg-steel-950 px-6 py-10 text-center">
    <p class="text-sm text-steel-400">
      &copy; {year} Gensteel. All rights reserved. · 28 Erinville Drive, Erin, Ontario N0B 1T0
    </p>
  </footer>
</BaseLayout>

<script>
  const form = document.getElementById("contact-form") as HTMLFormElement | null;
  const status = document.getElementById("form-status") as HTMLParagraphElement | null;

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    if (status) {
      status.classList.remove("hidden");
      status.textContent = "Sending...";
    }

    try {
      const formData = new FormData(form);
      const res = await fetch("/api/contact", {
        method: "POST",
        body: formData,
      });

      if (res.ok) {
        if (status) {
          status.textContent = "Thank you! We'll be in touch shortly.";
          status.className = "mt-4 text-center text-sm text-green-600";
        }
        form.reset();
      } else {
        throw new Error("Submission failed");
      }
    } catch {
      if (status) {
        status.textContent = "Something went wrong. Please email us at info@gensteel.ca or call +1 (519) 833-8555.";
        status.className = "mt-4 text-center text-sm text-red-500";
      }
    }
  });
</script>
