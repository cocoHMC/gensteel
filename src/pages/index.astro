---
import BaseLayout from "../layouts/BaseLayout.astro";

const year = new Date().getFullYear();
---

<BaseLayout>
  <!-- Header / Nav -->
  <header class="fixed top-0 z-50 w-full border-b border-white/10 bg-gensteel-blue/95 backdrop-blur-sm">
    <nav class="mx-auto flex max-w-7xl items-center justify-between px-6 py-4" aria-label="Main navigation">
      <a href="/" class="flex items-center gap-2 text-white no-underline">
        <span class="font-heading text-2xl font-bold tracking-tight">
          <span class="text-gensteel-orange">GEN</span>STEEL
        </span>
      </a>
      <div class="hidden items-center gap-8 md:flex">
        <a href="/#about" class="text-sm font-medium text-white/80 transition-colors hover:text-gensteel-orange">About</a>
        <a href="/#services" class="text-sm font-medium text-white/80 transition-colors hover:text-gensteel-orange">Services</a>
        <a href="/#projects" class="text-sm font-medium text-white/80 transition-colors hover:text-gensteel-orange">Projects</a>
        <a href="/blog" class="text-sm font-medium text-white/80 transition-colors hover:text-gensteel-orange">News</a>
        <a href="/#contact" class="rounded-md bg-gensteel-orange px-5 py-2.5 text-sm font-semibold text-white transition-colors hover:bg-gensteel-orange/90">Contact</a>
      </div>
      <!-- Mobile menu button -->
      <button
        id="mobile-menu-toggle"
        class="inline-flex items-center justify-center rounded-md p-2 text-white md:hidden"
        aria-label="Open menu"
      >
        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
        </svg>
      </button>
    </nav>
  </header>

  <!-- Hero Section -->
  <section class="relative flex min-h-screen items-center justify-center overflow-hidden bg-gensteel-blue px-6 pt-20">
    <!-- Background pattern -->
    <div class="absolute inset-0 opacity-10">
      <div class="absolute inset-0" style="background-image: radial-gradient(circle at 2px 2px, currentColor 1px, transparent 0); background-size: 40px 40px;"></div>
    </div>
    <!-- Orange accent blob -->
    <div class="absolute -right-40 -top-40 h-[600px] w-[600px] rounded-full bg-gensteel-orange/20 blur-3xl"></div>
    <div class="absolute -bottom-40 -left-40 h-[400px] w-[400px] rounded-full bg-gensteel-orange/10 blur-3xl"></div>

    <div class="relative z-10 mx-auto max-w-4xl text-center">
      <p class="mb-4 font-heading text-sm font-semibold uppercase tracking-[0.2em] text-gensteel-orange">
        Erin, Ontario
      </p>
      <h1 class="mb-6 font-heading text-5xl font-bold leading-tight text-white sm:text-6xl lg:text-7xl">
        Strength in Steel,<br />
        <span class="text-gensteel-orange">Vision in Design.</span>
      </h1>
      <p class="mx-auto mb-10 max-w-2xl text-lg leading-relaxed text-white/70">
        Full-service structural steel fabrication, installation, detailing, and design.
        Serving Ontario with precision, performance, and pride since day one.
      </p>
      <div class="flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
        <a href="/#contact" class="inline-flex rounded-lg bg-gensteel-orange px-8 py-4 font-heading text-base font-semibold text-white transition-all hover:bg-gensteel-orange/90 hover:shadow-lg hover:shadow-gensteel-orange/25">
          Get a Quote →
        </a>
        <a href="/#services" class="inline-flex rounded-lg border border-white/20 px-8 py-4 font-heading text-base font-semibold text-white transition-all hover:border-white/40 hover:bg-white/5">
          Our Services
        </a>
      </div>
    </div>
  </section>

  <!-- About Section -->
  <section id="about" class="bg-white px-6 py-24">
    <div class="mx-auto max-w-7xl">
      <div class="grid items-center gap-16 lg:grid-cols-2">
        <div>
          <p class="mb-3 font-heading text-sm font-semibold uppercase tracking-[0.2em] text-gensteel-orange">About Us</p>
          <h2 class="mb-6 font-heading text-4xl font-bold leading-tight text-steel-900 sm:text-5xl">
            Discover More<br />About Gensteel
          </h2>
          <p class="mb-6 text-lg leading-relaxed text-steel-600">
            Based in Erin, Ontario, Gensteel is a premier structural steel fabricating and
            installation company. We combine decades of hands-on experience with modern
            engineering to deliver steel solutions that stand the test of time.
          </p>
          <p class="mb-8 text-lg leading-relaxed text-steel-600">
            From design-build through final erection, our team brings precision to every
            beam, connection, and deck — whether it's a commercial tower, industrial
            facility, or custom architectural feature.
          </p>
          <div class="grid grid-cols-2 gap-6 border-t border-steel-200 pt-8">
            <div>
              <p class="font-heading text-2xl font-bold text-gensteel-blue">25+</p>
              <p class="text-sm text-steel-500">Years Experience</p>
            </div>
            <div>
              <p class="font-heading text-2xl font-bold text-gensteel-blue">200+</p>
              <p class="text-sm text-steel-500">Projects Delivered</p>
            </div>
            <div>
              <p class="font-heading text-2xl font-bold text-gensteel-blue">100%</p>
              <p class="text-sm text-steel-500">Ontario-Based</p>
            </div>
            <div>
              <p class="font-heading text-2xl font-bold text-gensteel-blue">24/7</p>
              <p class="text-sm text-steel-500">Project Support</p>
            </div>
          </div>
        </div>
        <div class="relative">
          <div class="aspect-[4/3] rounded-2xl bg-steel-100">
            <!-- Placeholder for image — replace with actual project photo -->
            <div class="flex h-full items-center justify-center text-steel-400">
              <svg class="h-16 w-16" fill="none" viewBox="0 0 24 24" stroke-width="1" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="m2.25 15.75 5.159-5.159a2.25 2.25 0 0 1 3.182 0l5.159 5.159m-1.5-1.5 1.409-1.409a2.25 2.25 0 0 1 3.182 0l2.909 2.909M3.75 21h16.5A2.25 2.25 0 0 0 22.5 18.75V5.25A2.25 2.25 0 0 0 20.25 3H3.75A2.25 2.25 0 0 0 1.5 5.25v13.5A2.25 2.25 0 0 0 3.75 21Zm10.5-11.25h.008v.008h-.008V9.75Zm.375 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Z" />
              </svg>
            </div>
          </div>
          <!-- Decorative element -->
          <div class="absolute -bottom-6 -right-6 -z-10 h-full w-full rounded-2xl border-2 border-gensteel-orange/30"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- Services Section -->
  <section id="services" class="bg-steel-50 px-6 py-24">
    <div class="mx-auto max-w-7xl">
      <div class="mx-auto mb-16 max-w-2xl text-center">
        <p class="mb-3 font-heading text-sm font-semibold uppercase tracking-[0.2em] text-gensteel-orange">What We Do</p>
        <h2 class="mb-6 font-heading text-4xl font-bold leading-tight text-steel-900 sm:text-5xl">
          Full-Service Steel Solutions
        </h2>
        <p class="text-lg leading-relaxed text-steel-600">
          From concept to completion, we handle every phase of structural steel work
          with in-house expertise and a commitment to quality.
        </p>
      </div>
      <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
        <!-- Service Card 1 -->
        <div class="group rounded-2xl border border-steel-200 bg-white p-8 transition-all hover:border-gensteel-orange/40 hover:shadow-lg">
          <div class="mb-5 inline-flex rounded-lg bg-gensteel-orange/10 p-3">
            <svg class="h-6 w-6 text-gensteel-orange" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17 17.25 21A2.652 2.652 0 0 0 21 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766M11.42 15.17l-4.655 5.653a2.548 2.548 0 1 1-3.586-3.586l6.837-5.63m5.108-.233c.55-.164 1.163-.188 1.743-.14a4.5 4.5 0 0 0 4.486-6.336l-3.276 3.277a3.004 3.004 0 0 1-2.25-2.25l3.276-3.276a4.5 4.5 0 0 0-6.336 4.486c.091 1.076-.071 2.264-.904 2.95l-.102.085m-1.745 1.437L5.909 7.5H4.5L2.25 3.75l1.5-1.5L7.5 4.5v1.409l4.26 4.26m-1.745 1.437 1.745-1.437m-6.615 8.206L15.75 15.75M4.867 19.125h.008v.008h-.008v-.008Z" />
            </svg>
          </div>
          <h3 class="mb-3 font-heading text-xl font-bold text-steel-900">Fabrication</h3>
          <p class="text-sm leading-relaxed text-steel-600">
            Precision-cut, welded, and finished structural steel components built
            to the most demanding specifications and codes.
          </p>
        </div>
        <!-- Service Card 2 -->
        <div class="group rounded-2xl border border-steel-200 bg-white p-8 transition-all hover:border-gensteel-orange/40 hover:shadow-lg">
          <div class="mb-5 inline-flex rounded-lg bg-gensteel-orange/10 p-3">
            <svg class="h-6 w-6 text-gensteel-orange" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
            </svg>
          </div>
          <h3 class="mb-3 font-heading text-xl font-bold text-steel-900">Installation</h3>
          <p class="text-sm leading-relaxed text-steel-600">
            Safe, efficient on-site erection by certified crews. We handle
            logistics, crane coordination, and final bolting.
          </p>
        </div>
        <!-- Service Card 3 -->
        <div class="group rounded-2xl border border-steel-200 bg-white p-8 transition-all hover:border-gensteel-orange/40 hover:shadow-lg">
          <div class="mb-5 inline-flex rounded-lg bg-gensteel-orange/10 p-3">
            <svg class="h-6 w-6 text-gensteel-orange" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="m3.75 13.5 10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75Z" />
            </svg>
          </div>
          <h3 class="mb-3 font-heading text-xl font-bold text-steel-900">Detailing &amp; Design</h3>
          <p class="text-sm leading-relaxed text-steel-600">
            Tekla and AutoCAD-driven shop drawings, connection design, and
            3D BIM coordination with project stakeholders.
          </p>
        </div>
        <!-- Service Card 4 -->
        <div class="group rounded-2xl border border-steel-200 bg-white p-8 transition-all hover:border-gensteel-orange/40 hover:shadow-lg">
          <div class="mb-5 inline-flex rounded-lg bg-gensteel-orange/10 p-3">
            <svg class="h-6 w-6 text-gensteel-orange" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 4.5h14.25M3 9h9.75M3 13.5h9.75m4.5-4.5v12m0 0-3.75-3.75M17.25 21l3.75-3.75" />
            </svg>
          </div>
          <h3 class="mb-3 font-heading text-xl font-bold text-steel-900">Metal Deck</h3>
          <p class="text-sm leading-relaxed text-steel-600">
            Supply and installation of steel roof deck, floor deck, and
            composite deck systems for any building type.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Projects Teaser -->
  <section id="projects" class="bg-gensteel-blue px-6 py-24">
    <div class="mx-auto max-w-7xl">
      <div class="mx-auto mb-16 max-w-2xl text-center">
        <p class="mb-3 font-heading text-sm font-semibold uppercase tracking-[0.2em] text-gensteel-orange">Our Work</p>
        <h2 class="mb-6 font-heading text-4xl font-bold leading-tight text-white sm:text-5xl">
          Projects That Stand Tall
        </h2>
        <p class="text-lg leading-relaxed text-white/70">
          Every project is a partnership. Here's a look at some of the structures
          we're proud to have brought to life across Ontario.
        </p>
      </div>
      <!-- Project grid placeholder -->
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {["Commercial", "Industrial", "Institutional", "Infrastructure", "Architectural", "Custom"].map((cat) => (
          <div class="group relative overflow-hidden rounded-2xl bg-steel-800 transition-all hover:shadow-xl hover:shadow-gensteel-orange/10">
            <div class="aspect-[4/3] bg-steel-700">
              <div class="flex h-full items-center justify-center text-steel-500">
                <svg class="h-12 w-12" fill="none" viewBox="0 0 24 24" stroke-width="1" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="m2.25 15.75 5.159-5.159a2.25 2.25 0 0 1 3.182 0l5.159 5.159m-1.5-1.5 1.409-1.409a2.25 2.25 0 0 1 3.182 0l2.909 2.909M3.75 21h16.5A2.25 2.25 0 0 0 22.5 18.75V5.25A2.25 2.25 0 0 0 20.25 3H3.75A2.25 2.25 0 0 0 1.5 5.25v13.5A2.25 2.25 0 0 0 3.75 21Zm10.5-11.25h.008v.008h-.008V9.75Zm.375 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Z" />
                </svg>
              </div>
            </div>
            <div class="p-5">
              <p class="font-heading text-sm font-semibold uppercase tracking-wide text-gensteel-orange">{cat}</p>
              <h3 class="mt-1 font-heading text-lg font-bold text-white">{cat} Steel Project</h3>
            </div>
          </div>
        ))}
      </div>
      <div class="mt-12 text-center">
        <a href="/projects" class="inline-flex rounded-lg border border-white/20 px-8 py-4 font-heading text-base font-semibold text-white transition-all hover:border-white/40 hover:bg-white/5">
          View All Projects →
        </a>
      </div>
    </div>
  </section>

  <!-- Contact Section -->
  <section id="contact" class="bg-white px-6 py-24">
    <div class="mx-auto max-w-7xl">
      <div class="grid gap-16 lg:grid-cols-2">
        <div>
          <p class="mb-3 font-heading text-sm font-semibold uppercase tracking-[0.2em] text-gensteel-orange">Get In Touch</p>
          <h2 class="mb-6 font-heading text-4xl font-bold leading-tight text-steel-900 sm:text-5xl">
            Let's Build<br />Together
          </h2>
          <p class="mb-10 text-lg leading-relaxed text-steel-600">
            Interested in collaborating with a leading structural steel fabricating
            and installation company? Share some details, and we'll reach out promptly.
            We're eager to engage with you!
          </p>
          <div class="space-y-5 border-t border-steel-200 pt-8">
            <div class="flex items-start gap-4">
              <svg class="mt-0.5 h-5 w-5 text-gensteel-orange" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />
              </svg>
              <div>
                <p class="font-heading text-sm font-semibold text-steel-900">Location</p>
                <p class="text-steel-600">28 Erinville Drive<br />Erin, Ontario N0B 1T0</p>
              </div>
            </div>
            <div class="flex items-start gap-4">
              <svg class="mt-0.5 h-5 w-5 text-gensteel-orange" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z" />
              </svg>
              <div>
                <p class="font-heading text-sm font-semibold text-steel-900">Phone &amp; Fax</p>
                <p class="text-steel-600">
                  Tel: +1 (519) 833-8555<br />
                  Fax: +1 (519) 833-1110
                </p>
              </div>
            </div>
            <div class="flex items-start gap-4">
              <svg class="mt-0.5 h-5 w-5 text-gensteel-orange" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
              </svg>
              <div>
                <p class="font-heading text-sm font-semibold text-steel-900">Email</p>
                <p class="text-steel-600">info@gensteel.ca</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Contact Form -->
        <div class="rounded-2xl border border-steel-200 bg-steel-50 p-8 lg:p-10">
          <form
            id="contact-form"
            class="space-y-6"
            method="POST"
            action="/api/contact"
          >
            <div class="grid gap-6 sm:grid-cols-2">
              <div>
                <label for="first-name" class="mb-1.5 block font-heading text-sm font-semibold text-steel-900">
                  First Name <span class="text-gensteel-orange">*</span>
                </label>
                <input
                  id="first-name"
                  name="firstName"
                  type="text"
                  required
                  class="w-full rounded-lg border border-steel-300 bg-white px-4 py-3 text-sm text-steel-900 placeholder:text-steel-400 focus:border-gensteel-orange focus:outline-none focus:ring-2 focus:ring-gensteel-orange/20"
                  placeholder="John"
                />
              </div>
              <div>
                <label for="last-name" class="mb-1.5 block font-heading text-sm font-semibold text-steel-900">
                  Last Name <span class="text-gensteel-orange">*</span>
                </label>
                <input
                  id="last-name"
                  name="lastName"
                  type="text"
                  required
                  class="w-full rounded-lg border border-steel-300 bg-white px-4 py-3 text-sm text-steel-900 placeholder:text-steel-400 focus:border-gensteel-orange focus:outline-none focus:ring-2 focus:ring-gensteel-orange/20"
                  placeholder="Doe"
                />
              </div>
            </div>
            <div>
              <label for="phone" class="mb-1.5 block font-heading text-sm font-semibold text-steel-900">
                Phone <span class="text-gensteel-orange">*</span>
              </label>
              <input
                id="phone"
                name="phone"
                type="tel"
                required
                class="w-full rounded-lg border border-steel-300 bg-white px-4 py-3 text-sm text-steel-900 placeholder:text-steel-400 focus:border-gensteel-orange focus:outline-none focus:ring-2 focus:ring-gensteel-orange/20"
                placeholder="(519) 555-0123"
              />
            </div>
            <div>
              <label for="email" class="mb-1.5 block font-heading text-sm font-semibold text-steel-900">
                Email <span class="text-gensteel-orange">*</span>
              </label>
              <input
                id="email"
                name="email"
                type="email"
                required
                class="w-full rounded-lg border border-steel-300 bg-white px-4 py-3 text-sm text-steel-900 placeholder:text-steel-400 focus:border-gensteel-orange focus:outline-none focus:ring-2 focus:ring-gensteel-orange/20"
                placeholder="john@company.com"
              />
            </div>
            <div>
              <label for="message" class="mb-1.5 block font-heading text-sm font-semibold text-steel-900">
                Message <span class="text-gensteel-orange">*</span>
              </label>
              <textarea
                id="message"
                name="message"
                rows={5}
                required
                class="w-full rounded-lg border border-steel-300 bg-white px-4 py-3 text-sm text-steel-900 placeholder:text-steel-400 focus:border-gensteel-orange focus:outline-none focus:ring-2 focus:ring-gensteel-orange/20"
                placeholder="Tell us about your project..."
              ></textarea>
            </div>
            <button
              type="submit"
              class="inline-flex w-full items-center justify-center rounded-lg bg-gensteel-orange px-8 py-4 font-heading text-base font-semibold text-white transition-all hover:bg-gensteel-orange/90 hover:shadow-lg hover:shadow-gensteel-orange/25"
            >
              Send Message →
            </button>
          </form>
          <p id="form-status" class="mt-4 text-center text-sm text-steel-500 hidden"></p>
        </div>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="bg-steel-950 px-6 py-16">
    <div class="mx-auto max-w-7xl">
      <div class="grid gap-12 sm:grid-cols-2 lg:grid-cols-4">
        <!-- Brand -->
        <div>
          <a href="/" class="mb-4 inline-block">
            <span class="font-heading text-xl font-bold tracking-tight text-white">
              <span class="text-gensteel-orange">GEN</span>STEEL
            </span>
          </a>
          <p class="text-sm leading-relaxed text-steel-400">
            Structural steel fabrication and installation. Building Ontario's future, one beam at a time.
          </p>
        </div>
        <!-- Quick Links -->
        <div>
          <h4 class="mb-4 font-heading text-sm font-semibold uppercase tracking-wider text-white">Quick Links</h4>
          <ul class="space-y-3">
            <li><a href="/#about" class="text-sm text-steel-400 transition-colors hover:text-gensteel-orange">About</a></li>
            <li><a href="/#services" class="text-sm text-steel-400 transition-colors hover:text-gensteel-orange">Services</a></li>
            <li><a href="/#projects" class="text-sm text-steel-400 transition-colors hover:text-gensteel-orange">Projects</a></li>
            <li><a href="/blog" class="text-sm text-steel-400 transition-colors hover:text-gensteel-orange">News &amp; Blog</a></li>
          </ul>
        </div>
        <!-- Contact -->
        <div>
          <h4 class="mb-4 font-heading text-sm font-semibold uppercase tracking-wider text-white">Contact</h4>
          <address class="space-y-3 text-sm not-italic text-steel-400">
            <p>28 Erinville Drive<br />Erin, Ontario N0B 1T0</p>
            <p>Tel: +1 (519) 833-8555</p>
            <p>Fax: +1 (519) 833-1110</p>
            <p>
