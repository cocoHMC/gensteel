<script>
  // Client-side form submission with vanilla JS (no React needed for this)
  const form = document.getElementById("contact-form") as HTMLFormElement | null;
  const status = document.getElementById("form-status") as HTMLParagraphElement | null;

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    if (status) {
      status.classList.remove("hidden");
      status.textContent = "Sending...";
    }

    try {
      const formData = new FormData(form);
      const res = await fetch("/api/contact", {
        method: "POST",
        body: formData,
      });

      if (res.ok) {
        if (status) {
          status.textContent = "Thank you! We'll be in touch shortly.";
          status.className = "mt-4 text-center text-sm text-green-600";
        }
        form.reset();
      } else {
        throw new Error("Submission failed");
      }
    } catch {
      if (status) {
        status.textContent = "Something went wrong. Please email us at info@gensteel.ca or call +1 (519) 833-8555.";
        status.className = "mt-4 text-center text-sm text-red-500";
      }
    }
  });
</script>
