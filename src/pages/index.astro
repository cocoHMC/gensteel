---
import BaseLayout from "../layouts/BaseLayout.astro";

const year = new Date().getFullYear();

// Hero background image (used as CSS background in hero section)
const heroImage = "/images/noss.jpg";

// Featured project images for the cards
const featuredProjects = [
  { src: "/images/gallery/IMG_6810.jpg", alt: "Steel structure erection", title: "Commercial Construction" },
  { src: "/images/gallery/IMG_6830.jpg", alt: "Steel beam installation", title: "Industrial Facility" },
  { src: "/images/gallery/IMG_6808.jpg", alt: "Architectural steelwork", title: "Institutional Build" },
  { src: "/images/gallery/IMG_6831.jpg", alt: "Metal deck installation", title: "Infrastructure" },
  { src: "/images/gallery/IMG_6223.jpg", alt: "Custom steel fabrication", title: "Architectural Steel" },
  { src: "/images/gallery/IMG_6059.jpg", alt: "Welded steel assembly", title: "Custom Fabrication" },
];
---

<BaseLayout>
  <!-- Header / Nav -->
  <header class="fixed top-0 z-50 w-full border-b border-white/10 bg-gensteel-blue/95 backdrop-blur-sm">
    <nav class="mx-auto flex max-w-7xl items-center justify-between px-6 py-4" aria-label="Main navigation">
      <a href="/" class="flex items-center gap-3 text-white no-underline">
        <img src="/images/logo.jpg" alt="Gensteel" class="h-10 w-auto" width="58" height="33" />
        <span class="font-heading text-2xl font-bold tracking-tight">
          <span class="text-gensteel-orange">GEN</span>STEEL
        </span>
      </a>
      <div class="hidden items-center gap-8 md:flex">
        <a href="/about" class="text-sm font-medium text-white/80 transition-colors hover:text-gensteel-orange">About</a>
        <a href="/#services" class="text-sm font-medium text-white/80 transition-colors hover:text-gensteel-orange">Services</a>
        <a href="/projects" class="text-sm font-medium text-white/80 transition-colors hover:text-gensteel-orange">Projects</a>
        <a href="/blog" class="text-sm font-medium text-white/80 transition-colors hover:text-gensteel-orange">News</a>
        <a href="/contact" class="rounded-md bg-gensteel-orange px-5 py-2.5 text-sm font-semibold text-white transition-colors hover:bg-gensteel-orange/90">Contact</a>
      </div>
      <button
        id="mobile-menu-toggle"
        class="inline-flex items-center justify-center rounded-md p-2 text-white md:hidden"
        aria-label="Open menu"
      >
        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
        </svg>
      </button>
    </nav>
  </header>

  <!-- Hero Section -->
  <section class="relative flex min-h-screen items-center justify-center overflow-hidden bg-gensteel-blue px-6 pt-20">
    <!-- Background image overlay -->
    <div class="absolute inset-0">
      <img
        src="/images/noss.jpg"
        alt="Gensteel structural steel project"
        class="h-full w-full object-cover opacity-40"
        loading="eager"
        width="780" height="585"
      />
    </div>
    <!-- Orange accent blob -->
    <div class="absolute -right-40 -top-40 h-[600px] w-[600px] rounded-full bg-gensteel-orange/20 blur-3xl"></div>
    <div class="absolute -bottom-40 -left-40 h-[400px] w-[400px] rounded-full bg-gensteel-orange/10 blur-3xl"></div>

    <div class="relative z-10 mx-auto max-w-4xl text-center">
      <p class="mb-4 font-heading text-sm font-semibold uppercase tracking-[0.2em] text-gensteel-orange">
        Erin, Ontario · Est. 1994
      </p>
      <h1 class="mb-6 font-heading text-5xl font-bold leading-tight text-white sm:text-6xl lg:text-7xl">
        Strength in Steel,<br />
        <span class="text-gensteel-orange">Vision in Design.</span>
      </h1>
      <p class="mx-auto mb-10 max-w-2xl text-lg leading-relaxed text-white/70">
        Complete steel design, fabrication, and installation — accredited by the
        Canadian Welding Bureau. From concept to completion, we deliver structural
        steel solutions that stand the test of time.
      </p>
      <div class="flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
        <a href="/contact" class="inline-flex rounded-lg bg-gensteel-orange px-8 py-4 font-heading text-base font-semibold text-white transition-all hover:bg-gensteel-orange/90 hover:shadow-lg hover:shadow-gensteel-orange/25">
          Get a Quote →
        </a>
        <a href="/projects" class="inline-flex rounded-lg border border-white/20 px-8 py-4 font-heading text-base font-semibold text-white transition-all hover:border-white/40 hover:bg-white/5">
          View Our Work
        </a>
      </div>
    </div>
  </section>

  <!-- About Section -->
  <section id="about" class="bg-white px-6 py-24">
    <div class="mx-auto max-w-7xl">
      <div class="grid items-center gap-16 lg:grid-cols-2">
        <div>
          <p class="mb-3 font-heading text-sm font-semibold uppercase tracking-[0.2em] text-gensteel-orange">About Us</p>
          <h2 class="mb-6 font-heading text-4xl font-bold leading-tight text-steel-900 sm:text-5xl">
            Built on Experience.<br />Driven by Precision.
          </h2>
          <p class="mb-6 text-lg leading-relaxed text-steel-600">
            Established in 1994 by Joe Henriques, Gensteel began as a small miscellaneous
            metal fabricator and has grown into a complete steel design, fabrication, and
            installation service accredited by the Canadian Welding Bureau (CWB).
          </p>
          <p class="mb-8 text-lg leading-relaxed text-steel-600">
            Our 13,000 square foot facility in Erin, Ontario, houses advanced cutting technology
            that delivers high precision on every project. From community centres and schools to
            hospitals and office complexes, we ensure efficient completion regardless of location
            or size.
          </p>
          <div class="grid grid-cols-2 gap-6 border-t border-steel-200 pt-8">
            <div>
              <p class="font-heading text-2xl font-bold text-gensteel-blue">1994</p>
              <p class="text-sm text-steel-500">Established</p>
            </div>
            <div>
              <p class="font-heading text-2xl font-bold text-gensteel-blue">13,000</p>
              <p class="text-sm text-steel-500">Sq Ft Facility</p>
            </div>
            <div>
              <p class="font-heading text-2xl font-bold text-gensteel-blue">CWB</p>
              <p class="text-sm text-steel-500">Certified</p>
            </div>
            <div>
              <p class="font-heading text-2xl font-bold text-gensteel-blue">ON</p>
              <p class="text-sm text-steel-500">Serving All Ontario</p>
            </div>
          </div>
          <div class="mt-8">
            <a href="/about" class="inline-flex items-center gap-2 font-heading text-sm font-semibold text-gensteel-orange transition-colors hover:text-gensteel-blue">
              Learn more about Gensteel
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" /></svg>
            </a>
          </div>
        </div>
        <div class="relative">
          <img
            src="/images/gallery/IMG_6809.jpg"
            alt="Gensteel facility and steel fabrication"
            class="aspect-[4/3] w-full rounded-2xl object-cover shadow-lg"
            width="780" height="585"
            loading="lazy"
          />
          <!-- Decorative element -->
          <div class="absolute -bottom-6 -right-6 -z-10 h-full w-full rounded-2xl border-2 border-gensteel-orange/30"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- Services Section -->
  <section id="services" class="bg-steel-50 px-6 py-24">
    <div class="mx-auto max-w-7xl">
      <div class="mx-auto mb-16 max-w-2xl text-center">
        <p class="mb-3 font-heading text-sm font-semibold uppercase tracking-[0.2em] text-gensteel-orange">What We Do</p>
        <h2 class="mb-6 font-heading text-4xl font-bold leading-tight text-steel-900 sm:text-5xl">
          Full-Service Steel Solutions
        </h2>
        <p class="text-lg leading-relaxed text-steel-600">
          From concept to completion, we handle every phase of structural steel work
          with in-house expertise and a commitment to quality.
        </p>
      </div>
      <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
        <!-- Fabrication -->
        <div class="group rounded-2xl border border-steel-200 bg-white p-8 transition-all hover:border-gensteel-orange/40 hover:shadow-lg">
          <div class="mb-5 inline-flex rounded-lg bg-gensteel-orange/10 p-3">
            <svg class="h-6 w-6 text-gensteel-orange" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17 17.25 21A2.652 2.652 0 0 0 21 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766M11.42 15.17l-4.655 5.653a2.548 2.548 0 1 1-3.586-3.586l6.837-5.63m5.108-.233c.55-.164 1.163-.188 1.743-.14a4.5 4.5 0 0 0 4.486-6.336l-3.276 3.277a3.004 3.004 0 0 1-2.25-2.25l3.276-3.276a4.5 4.5 0 0 0-6.336 4.486c.091 1.076-.071 2.264-.904 2.95l-.102.085m-1.745 1.437L5.909 7.5H4.5L2.25 3.75l1.5-1.5L7.5 4.5v1.409l4.26 4.26m-1.745 1.437 1.745-1.437m-6.615 8.206L15.75 15.75M4.867 19.125h.008v.008h-.008v-.008Z" />
            </svg>
          </div>
          <h3 class="mb-3 font-heading text-xl font-bold text-steel-900">Fabrication</h3>
          <p class="text-sm leading-relaxed text-steel-600">
            CWB-certified precision cutting, welding, and finishing of structural
            steel components built to the most demanding specifications.
          </p>
        </div>
        <!-- Installation -->
        <div class="group rounded-2xl border border-steel-200 bg-white p-8 transition-all hover:border-gensteel-orange/40 hover:shadow-lg">
          <div class="mb-5 inline-flex rounded-lg bg-gensteel-orange/10 p-3">
            <svg class="h-6 w-6 text-gensteel-orange" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
            </svg>
          </div>
          <h3 class="mb-3 font-heading text-xl font-bold text-steel-900">Installation</h3>
          <p class="text-sm leading-relaxed text-steel-600">
            Safe, efficient on-site erection by certified crews. We handle
            logistics, crane coordination, and final bolting on schedule.
          </p>
        </div>
        <!-- Detailing & Design -->
        <div class="group rounded-2xl border border-steel-200 bg-white p-8 transition-all hover:border-gensteel-orange/40 hover:shadow-lg">
          <div class="mb-5 inline-flex rounded-lg bg-gensteel-orange/10 p-3">
            <svg class="h-6 w-6 text-gensteel-orange" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="m3.75 13.5 10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75Z" />
            </svg>
          </div>
          <h3 class="mb-3 font-heading text-xl font-bold text-steel-900">Detailing &amp; Design</h3>
          <p class="text-sm leading-relaxed text-steel-600">
            Tekla and AutoCAD-driven shop drawings, connection design, and
            3D BIM coordination with all project stakeholders.
          </p>
        </div>
        <!-- Metal Deck -->
        <div class="group rounded-2xl border border-steel-200 bg-white p-8 transition-all hover:border-gensteel-orange/40 hover:shadow-lg">
          <div class="mb-5 inline-flex rounded-lg bg-gensteel-orange/10 p-3">
            <svg class="h-6 w-6 text-gensteel-orange" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 4.5h14.25M3 9h9.75M3 13.5h9.75m4.5-4.5v12m0 0-3.75-3.75M17.25 21l3.75-3.75" />
            </svg>
          </div>
          <h3 class="mb-3 font-heading text-xl font-bold text-steel-900">Metal Deck</h3>
          <p class="text-sm leading-relaxed text-steel-600">
            Supply and installation of steel roof deck, floor deck, and
            composite deck systems for any building type.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Projects Teaser -->
  <section id="projects" class="bg-gensteel-blue px-6 py-24">
    <div class="mx-auto max-w-7xl">
      <div class="mx-auto mb-16 max-w-2xl text-center">
        <p class="mb-3 font-heading text-sm font-semibold uppercase tracking-[0.2em] text-gensteel-orange">Our Work</p>
        <h2 class="mb-6 font-heading text-4xl font-bold leading-tight text-white sm:text-5xl">
          Projects That Stand Tall
        </h2>
        <p class="text-lg leading-relaxed text-white/70">
          Every project is a partnership. Browse a selection of the structures
          we're proud to have brought to life across Ontario.
        </p>
      </div>
      <!-- Project grid -->
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {featuredProjects.map((project) => (
          <div class="group relative overflow-hidden rounded-2xl bg-steel-800 transition-all hover:shadow-xl hover:shadow-gensteel-orange/10">
            <div class="aspect-[4/3]">
              <img
                src={project.src}
                alt={project.alt}
                class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                loading="lazy"
                width="400" height="300"
              />
            </div>
            <div class="absolute inset-0 bg-gradient-to-t from-steel-950/80 via-transparent to-transparent"></div>
            <div class="absolute bottom-0 left-0 right-0 p-5">
              <h3 class="font-heading text-lg font-bold text-white">{project.title}</h3>
            </div>
          </div>
        ))}
      </div>
      <div class="mt-12 text-center">
        <a href="/projects" class="inline-flex rounded-lg border border-white/20 px-8 py-4 font-heading text-base font-semibold text-white transition-all hover:border-white/40 hover:bg-white/5">
          View All Projects →
        </a>
      </div>
    </div>
  </section>

  <!-- Contact Teaser -->
  <section id="contact" class="bg-steel-50 px-6 py-24">
    <div class="mx-auto max-w-4xl text-center">
      <p class="mb-3 font-heading text-sm font-semibold uppercase tracking-[0.2em] text-gensteel-orange">Get In Touch</p>
      <h2 class="mb-6 font-heading text-4xl font-bold leading-tight text-steel-900 sm:text-5xl">
        Let's Build Together
      </h2>
      <p class="mx-auto mb-10 max-w-2xl text-lg leading-relaxed text-steel-600">
        Interested in collaborating with a leading structural steel fabricating
        and installation company? Share some details, and we'll reach out promptly.
      </p>
      <div class="flex flex-col items-center justify-center gap-4 sm:flex-row">
        <a href="/contact" class="inline-flex items-center rounded-lg bg-gensteel-orange px-8 py-4 font-heading text-base font-semibold text-white transition-all hover:bg-gensteel-orange/90 hover:shadow-lg hover:shadow-gensteel-orange/25">
          Contact Us →
        </a>
        <a href="tel:+15198338555" class="inline-flex items-center gap-2 rounded-lg border border-steel-300 px-8 py-4 font-heading text-base font-semibold text-steel-700 transition-all hover:border-gensteel-orange hover:text-gensteel-orange">
          <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z" />
          </svg>
          (519) 833-8555
        </a>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="bg-steel-950 px-6 py-16">
    <div class="mx-auto max-w-7xl">
      <div class="grid gap-12 sm:grid-cols-2 lg:grid-cols-4">
        <!-- Brand -->
        <div>
          <a href="/" class="mb-4 inline-flex items-center gap-3">
            <img src="/images/logo.jpg" alt="Gensteel" class="h-8 w-auto" width="58" height="33" />
            <span class="font-heading text-xl font-bold tracking-tight text-white">
              <span class="text-gensteel-orange">GEN</span>STEEL
            </span>
          </a>
          <p class="text-sm leading-relaxed text-steel-400">
            CWB-certified structural steel fabrication and installation.
            Building Ontario's future since 1994.
          </p>
          <div class="mt-4 flex gap-3">
            <img src="/images/cisc-cert.jpg" alt="CISC/ICCA Member" class="h-10 w-auto" loading="lazy" />
            <img src="/images/cwb-cert.jpg" alt="CWB Certified" class="h-10 w-auto" loading="lazy" />
          </div>
        </div>
        <!-- Quick Links -->
        <div>
          <h4 class="mb-4 font-heading text-sm font-semibold uppercase tracking-wider text-white">Quick Links</h4>
          <ul class="space-y-3">
            <li><a href="/about" class="text-sm text-steel-400 transition-colors hover:text-gensteel-orange">About</a></li>
            <li><a href="/#services" class="text-sm text-steel-400 transition-colors hover:text-gensteel-orange">Services</a></li>
            <li><a href="/projects" class="text-sm text-steel-400 transition-colors hover:text-gensteel-orange">Projects</a></li>
            <li><a href="/blog" class="text-sm text-steel-400 transition-colors hover:text-gensteel-orange">News &amp; Blog</a></li>
            <li><a href="/contact" class="text-sm text-steel-400 transition-colors hover:text-gensteel-orange">Contact</a></li>
          </ul>
        </div>
        <!-- Contact -->
        <div>
          <h4 class="mb-4 font-heading text-sm font-semibold uppercase tracking-wider text-white">Contact</h4>
          <address class="space-y-3 text-sm not-italic text-steel-400">
            <p>28 Erinville Drive<br />Erin, Ontario N0B 1T0</p>
            <p>Tel: +1 (519) 833-8555</p>
            <p>Fax: +1 (519) 833-1110</p>
            <p>
              <a href="mailto:info@gensteel.ca" class="transition-colors hover:text-gensteel-orange">info@gensteel.ca</a>
            </p>
          </address>
        </div>
        <!-- Hours -->
        <div>
          <h4 class="mb-4 font-heading text-sm font-semibold uppercase tracking-wider text-white">Hours</h4>
          <ul class="space-y-2 text-sm text-steel-400">
            <li class="flex justify-between"><span>Mon – Fri</span><span>7:00 AM – 5:00 PM</span></li>
            <li class="flex justify-between"><span>Sat</span><span>By Appointment</span></li>
            <li class="flex justify-between"><span>Sun</span><span>Closed</span></li>
          </ul>
        </div>
      </div>
      <!-- Bottom bar -->
      <div class="mt-12 border-t border-white/10 pt-8">
        <div class="flex flex-col items-center justify-between gap-4 sm:flex-row">
          <p class="text-sm text-steel-400">
            &copy; {year} Gensteel. All rights reserved. Built in Erin, Ontario 🇨🇦
          </p>
          <div class="flex gap-6">
            <a href="https://instagram.com" target="_blank" rel="noopener noreferrer" class="text-steel-400 transition-colors hover:text-gensteel-orange" aria-label="Instagram">
              <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
            </a>
            <a href="https://youtube.com" target="_blank" rel="noopener noreferrer" class="text-steel-400 transition-colors hover:text-gensteel-orange" aria-label="YouTube">
              <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </footer>
</BaseLayout>

<script>
  // Client-side form submission with vanilla JS (no React needed for this)
  const form = document.getElementById("contact-form") as HTMLFormElement | null;
  const status = document.getElementById("form-status") as HTMLParagraphElement | null;

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    if (status) {
      status.classList.remove("hidden");
      status.textContent = "Sending...";
    }

    try {
      const formData = new FormData(form);
      const res = await fetch("/api/contact", {
        method: "POST",
        body: formData,
      });

      if (res.ok) {
        if (status) {
          status.textContent = "Thank you! We'll be in touch shortly.";
          status.className = "mt-4 text-center text-sm text-green-600";
        }
        form.reset();
      } else {
        throw new Error("Submission failed");
      }
    } catch {
      if (status) {
        status.textContent = "Something went wrong. Please email us at info@gensteel.ca or call +1 (519) 833-8555.";
        status.className = "mt-4 text-center text-sm text-red-500";
      }
    }
  });
</script>
