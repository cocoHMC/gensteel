---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.slug || post.id.replace(/\.md$/, "") },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();
---

<BaseLayout>
  <article class="bg-white px-6 pb-24 pt-32">
    <div class="mx-auto max-w-3xl">
      <header class="mb-12">
        <p class="mb-3 font-heading text-xs font-semibold uppercase tracking-wider text-gensteel-orange">
          <time datetime={post.data.pubDate.toISOString()}>
            {post.data.pubDate.toLocaleDateString("en-CA", {
              year: "numeric",
              month: "long",
              day: "numeric",
            })}
          </time>
          {post.data.updatedDate && (
            <span> · Updated {post.data.updatedDate.toLocaleDateString("en-CA", {
              year: "numeric",
              month: "long",
              day: "numeric",
            })}</span>
          )}
        </p>
        <h1 class="font-heading text-4xl font-bold leading-tight text-steel-900 sm:text-5xl">
          {post.data.title}
        </h1>
        <p class="mt-4 text-lg text-steel-500">{post.data.description}</p>
        <div class="mt-4 flex flex-wrap gap-2">
          {post.data.tags.map((tag) => (
            <span class="rounded-full bg-steel-100 px-3 py-1 font-heading text-xs font-semibold uppercase tracking-wide text-steel-500">
              {tag}
            </span>
          ))}
        </div>
      </header>

      <div class="prose prose-steel prose-lg max-w-none">
        <Content />
      </div>
    </div>
  </article>

  <footer class="bg-steel-950 px-6 py-8 text-center">
    <p class="text-sm text-steel-400">
      &copy; {new Date().getFullYear()} Gensteel. All rights reserved.
    </p>
  </footer>
</BaseLayout>
