---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const posts = await getCollection("blog", ({ data }) => !data.draft);
posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout>
  <!-- Header placeholder for nav — extend BaseLayout later -->
  <section class="bg-gensteel-blue px-6 pb-16 pt-32">
    <div class="mx-auto max-w-3xl text-center">
      <p class="mb-3 font-heading text-sm font-semibold uppercase tracking-[0.2em] text-gensteel-orange">News &amp; Insights</p>
      <h1 class="font-heading text-4xl font-bold leading-tight text-white sm:text-5xl">
        Gensteel Blog
      </h1>
      <p class="mt-4 text-lg text-white/70">
        Project updates, industry perspectives, and company news from the team in Erin, Ontario.
      </p>
    </div>
  </section>

  <section class="bg-white px-6 py-16">
    <div class="mx-auto max-w-4xl">
      {
        posts.length === 0 ? (
          <p class="text-center text-steel-500">No posts yet — check back soon.</p>
        ) : (
          <div class="space-y-12">
            {posts.map((post) => (
              <article class="border-b border-steel-200 pb-12 last:border-0">
                <p class="mb-2 font-heading text-xs font-semibold uppercase tracking-wider text-gensteel-orange">
                  {post.data.pubDate.toLocaleDateString("en-CA", {
                    year: "numeric",
                    month: "long",
                    day: "numeric",
                  })}
                </p>
                <a href={`/blog/${post.id}`} class="group no-underline">
                  <h2 class="mb-3 font-heading text-2xl font-bold text-steel-900 transition-colors group-hover:text-gensteel-orange">
                    {post.data.title}
                  </h2>
                </a>
                <p class="text-steel-600">{post.data.description}</p>
                {post.data.tags.length > 0 && (
                  <div class="mt-4 flex flex-wrap gap-2">
                    {post.data.tags.map((tag) => (
                      <span class="rounded-full bg-steel-100 px-3 py-1 font-heading text-xs font-semibold uppercase tracking-wide text-steel-500">
                        {tag}
                      </span>
                    ))}
                  </div>
                )}
              </article>
            ))}
          </div>
        )
      }
    </div>
  </section>

  <footer class="bg-steel-950 px-6 py-8 text-center">
    <p class="text-sm text-steel-400">
      &copy; {new Date().getFullYear()} Gensteel. All rights reserved.
    </p>
  </footer>
</BaseLayout>
